# .env.example — copy to .env and fill in your values.
# .env is git-ignored; this template is committed so contributors know
# what variables the project supports.

# ── Researcher / branding ─────────────────────────────────────────────────────
# Displayed in the terminal header and HTML report.
RESEARCHER_NAME="Parag Bagade"
GITHUB_REPO_URL="https://github.com/parag25mcf10022/OverflowGuard"

# ── Output ────────────────────────────────────────────────────────────────────
# Directory where HTML reports are saved (default: results)
# RESULTS_DIR=results

# ── GitHub (v8.1 — repo scanning) ─────────────────────────────────────────────
# Personal access token for private repos or to avoid the 60 req/hr limit.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Fuzzer tuning ─────────────────────────────────────────────────────────────
# Seconds before a single fuzz payload attempt times out (default: 1.5)
# FUZZ_TIMEOUT=1.5

# ── v9.0 Analysis engine ─────────────────────────────────────────────────────
# Set to 0 to skip tree-sitter analysis and fall back to regex.
# OVERFLOWGUARD_NO_TREESITTER=0

# ── Tool paths (override if not in PATH) ──────────────────────────────────────
# CPPCHECK_BIN=cppcheck
# CLANG_TIDY_BIN=clang-tidy
# BANDIT_BIN=bandit
# SEMGREP_BIN=semgrep
# INFER_BIN=infer
